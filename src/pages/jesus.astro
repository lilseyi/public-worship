---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/ui/Container.astro";
import JesusSection from "../components/sections/JesusSection.astro";

const sections = [
  {
    label: "Father",
    verse:
      "The Spirit you received does not make you slaves, so that you live in fear again; rather, the Spirit you received brought about your adoption to sonship. And by him we cry, 'Abba, Father.'",
    reference: "Romans 8:15 (NIV)",
    body: "At the heart of the gospel is the staggering claim that we who believe in Jesus Christ are adopted into God's family by grace, not fear. The Father is not far. He is not stern. Through Christ's blood we are made sons and daughters who can climb into the lap of a perfect Father — one who delights in us, knows us by name, and never withholds the inheritance of mercy.",
    illustration: "/images/jesus-father.svg",
    bg: "pink" as const,
  },
  {
    label: "Husband",
    verse:
      "Husbands, love your wives, just as Christ loved the church and gave himself up for her to make her holy, cleansing her by the washing with water through the word.",
    reference: "Ephesians 5:25–26 (NIV)",
    body: "Christ does not court us from a distance. He enters into covenant in a way that makes His own bride beautiful. He laid down His life so that we, the broken Church, could walk into a wedding fully clothed in His righteousness. Our sacrifice is to step into the joy of being chosen, kept, and pursued — not to perform our way into being lovable.",
    illustration: "/images/jesus-husband.svg",
    bg: "peach" as const,
  },
  {
    label: "Friend",
    verse:
      "I no longer call you servants, because a servant does not know his master's business. Instead, I have called you friends, for everything that I learned from my Father I have made known to you.",
    reference: "John 15:15 (NIV)",
    body: "There is something significant about a relationship that calls those inside it friends. We are not employees of God, kept at arm's length to do tasks we don't understand. We are friends — confided in, trusted with the things of the Father. Jesus reveals His business and walks at our pace.",
    illustration: "/images/jesus-friend.svg",
    bg: "mint" as const,
  },
];
---

<BaseLayout
  title="Jesus — Father, Husband, Friend"
  description="Three relational pictures of Jesus from Scripture: Father, Husband, Friend. The doorway to faith is belief — not earning."
>
  <section class="py-10 sm:py-16">
    <Container size="default">
      <blockquote
        class="mx-auto max-w-3xl text-center font-display text-2xl sm:text-3xl md:text-4xl text-ink leading-snug"
      >
        "I am the <span class="text-red-500">Way, Truth,</span> and
        <span class="text-red-500">Life</span>. No one comes to the Father
        except through me"
        <cite class="block mt-3 text-sm not-italic font-medium text-ink/65">
          — Jesus, Son of God
        </cite>
      </blockquote>
    </Container>
  </section>

  <section class="pb-12">
    <Container size="default">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-ink mb-10">
        Father. Husband. Friend.
      </h2>

      <div class="flex flex-col gap-6">
        {
          sections.map((s) => (
            <JesusSection
              label={s.label}
              verse={s.verse}
              reference={s.reference}
              body={s.body}
              illustration={s.illustration}
              bg={s.bg}
            />
          ))
        }

        <article class="relative overflow-hidden rounded-3xl px-7 py-9 sm:px-10 sm:py-12 bg-lavender">
          <h3 class="font-display text-xl font-semibold mb-4 text-purple-800">
            Accepting the Father, Husband, and Friend
          </h3>
          <blockquote
            class="mb-5 font-display text-xl sm:text-2xl text-ink/85 leading-snug"
          >
            "But Scripture has locked up everything under the control of sin,
            so that what was promised, being given through faith in Jesus
            Christ, might be given to those who believe."
            <cite class="block mt-2 text-sm not-italic font-medium text-ink/65">
              — Galatians 3:22 (NIV)
            </cite>
          </blockquote>
          <p class="text-ink/85 leading-relaxed max-w-prose">
            The doorway is belief. Not the size of your faith, not your résumé,
            not your performance. Step in by trusting the One who stepped down
            for you. That is the entry point. That is how the journey begins.
          </p>
          <img
            src="/images/jesus-accept.svg"
            alt=""
            aria-hidden="true"
            class="absolute right-4 bottom-4 h-16 w-16 sm:h-20 sm:w-20 opacity-80"
            width="80"
            height="80"
          />
        </article>
      </div>
    </Container>
  </section>

  <section class="py-12 sm:py-20 text-center">
    <Container size="default">
      <h2
        class="font-display text-3xl sm:text-4xl font-semibold text-ink leading-tight max-w-2xl mx-auto"
      >
        Brought to you by Fiery Word, a gospel publication
      </h2>
      <p class="mt-4 text-ink/70">
        Visit
        <a
          href="https://fieryword.blog"
          class="text-red-500 underline underline-offset-2"
          target="_blank"
          rel="noopener noreferrer">fieryword.blog</a
        > for more gospel resources.
      </p>
    </Container>
  </section>
</BaseLayout>
