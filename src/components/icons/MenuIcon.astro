---
export interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <line x1="4" y1="8" x2="20" y2="8"></line>
  <line x1="4" y1="16" x2="20" y2="16"></line>
</svg>
