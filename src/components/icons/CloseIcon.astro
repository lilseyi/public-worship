---
export interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  class={className}
  aria-hidden="true"
>
  <line x1="6" y1="6" x2="18" y2="18"></line>
  <line x1="18" y1="6" x2="6" y2="18"></line>
</svg>
