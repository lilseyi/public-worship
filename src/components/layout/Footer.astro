---
import Container from "../ui/Container.astro";
import Logo from "../icons/Logo.astro";
import { asset } from "../../lib/asset";

export interface Props {
  brand?: "public-worship" | "global-echo";
}

const { brand = "public-worship" } = Astro.props;
const home = asset(brand === "global-echo" ? "/ge" : "/");
const beliefsHref = asset("/beliefs");

const navLinks = [
  { label: "About", href: `${home}#about` },
  { label: "Impact", href: `${home}#impact` },
  { label: "Links", href: `${home}#links` },
  { label: "FAQ", href: `${home}#faq` },
];
---

{/* Source footer is a single transparent panel: centered logo, nav row, then a
 * bottom legal row with copyright + beliefs link. No sky-blue panel, rounded
 * card, or pink bottom strip — those were overdesigned. */}
<footer class="mt-32 sm:mt-44 pb-12">
  <Container size="wide">
    <div class="flex flex-col items-center gap-8">
      <a href={home} aria-label="Home">
        <Logo brand={brand} class="h-9" />
      </a>
      <nav
        class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
        aria-label="Footer navigation"
      >
        {
          navLinks.map((l) => (
            <a href={l.href} class="text-base text-ink hover:text-red-500">
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>

    {/* Source legal row: 14px text on left, accent-dark red link on right. */}
    <div
      class="mt-12 flex flex-col sm:flex-row items-center justify-between gap-3 text-sm text-ink"
    >
      <span>© 2025, All Rights Reserved</span>
      <a
        href={beliefsHref}
        class="text-red-accentDark underline-offset-2 hover:underline"
        >Statement of Beliefs</a
      >
    </div>
  </Container>
</footer>
