---
import Container from "../ui/Container.astro";
import Logo from "../icons/Logo.astro";
import { asset } from "../../lib/asset";

export interface Props {
  brand?: "public-worship" | "global-echo";
}

const { brand = "public-worship" } = Astro.props;
const home = asset(brand === "global-echo" ? "/ge" : "/");
const beliefsHref = asset("/beliefs");

const navLinks = [
  { label: "About", href: `${home}#about` },
  { label: "Impact", href: `${home}#impact` },
  { label: "Links", href: `${home}#links` },
  { label: "FAQ", href: `${home}#faq` },
];

const wavyHref = asset("/decor/wavy-texture-section.svg");
---

<footer class="mt-20">
  <div class="mx-3 sm:mx-6">
    {/* Main footer panel: sky-blue background with the section wave pattern overlaid. */}
    <div class="relative overflow-hidden rounded-t-3xl bg-sky">
      <div
        class="pointer-events-none absolute inset-0 opacity-90"
        aria-hidden="true"
        style={`background-image: url(${wavyHref}); background-size: cover; background-position: center;`}
      />
      <Container size="wide" class="relative px-6 pt-16 pb-14 sm:pt-20 sm:pb-16">
        <div class="flex flex-col items-center gap-8">
          <a href={home} aria-label="Home">
            <Logo brand={brand} class="h-10" />
          </a>
          <nav
            class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3"
            aria-label="Footer navigation"
          >
            {
              navLinks.map((l) => (
                <a href={l.href} class="font-medium text-ink hover:text-red-500">
                  {l.label}
                </a>
              ))
            }
          </nav>
        </div>
      </Container>
    </div>

    {/* Bottom strip with copyright + Statement of Beliefs */}
    <div class="rounded-b-3xl bg-pink-band/80">
      <Container
        size="wide"
        class="flex flex-col sm:flex-row items-center justify-between gap-3 px-6 py-4 text-sm text-ink/80"
      >
        <span>© 2025, All Rights Reserved</span>
        <a
          href={beliefsHref}
          class="text-red-600 underline-offset-2 hover:underline"
          >Statement of Beliefs</a
        >
      </Container>
    </div>
  </div>
</footer>
