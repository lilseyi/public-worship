---
import Eyebrow from "./Eyebrow.astro";

export interface Props {
  eyebrow?: string;
  eyebrowIcon?: "sparkle" | "pray";
  align?: "left" | "center";
  as?: "h1" | "h2";
  class?: string;
}

const {
  eyebrow,
  eyebrowIcon = "sparkle",
  align = "center",
  as: Tag = "h2",
  class: className = "",
} = Astro.props;

const alignClass =
  align === "center" ? "items-center text-center" : "items-start text-left";
const headingSize =
  Tag === "h1"
    ? "text-4xl sm:text-5xl md:text-6xl"
    : "text-3xl sm:text-4xl md:text-5xl";
---

<div class={`flex flex-col gap-4 ${alignClass} ${className}`}>
  {eyebrow && <Eyebrow icon={eyebrowIcon}>{eyebrow}</Eyebrow>}
  <Tag class={`font-display font-normal leading-[1.05] ${headingSize}`}>
    <slot />
  </Tag>
  {
    Astro.slots.has("description") && (
      <p class="max-w-prose text-base text-ink/70 sm:text-lg">
        <slot name="description" />
      </p>
    )
  }
</div>
