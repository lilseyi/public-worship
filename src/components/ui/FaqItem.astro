---
import ChevronIcon from "../icons/ChevronIcon.astro";

export interface Props {
  question: string;
  answerHtml: string;
}

const { question, answerHtml } = Astro.props;
---

<details
  class="group border-b border-ink/10 py-4 [&_summary::-webkit-details-marker]:hidden"
>
  <summary
    class="flex cursor-pointer list-none items-start justify-between gap-4 py-2 text-left font-medium text-ink"
  >
    <span class="text-base sm:text-lg">{question}</span>
    <ChevronIcon
      class="mt-1 h-5 w-5 flex-shrink-0 text-red-500 transition-transform duration-200 group-open:rotate-180"
    />
  </summary>
  <div class="pw-prose mt-3 text-ink/80" set:html={answerHtml}></div>
</details>
