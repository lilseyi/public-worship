---
import { asset } from "../../lib/asset";

export interface Props {
  title: string;
  subtitle?: string;
  url: string;
  thumbnail?: string;
  bgImage?: string;
  cta?: string;
  align?: "center" | "topLeft";
}

const {
  title,
  subtitle,
  url,
  thumbnail,
  bgImage,
  cta,
  align = "center",
} = Astro.props;

const thumbSrc = thumbnail ? asset(thumbnail) : null;
const bgSrc = bgImage ? asset(bgImage) : null;

const isExternal = /^https?:|^mailto:/.test(url);
const externalAttrs = isExternal
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};

// Source: padding 48px, 16px radius, flat #F9DFDF background, no aspect ratio
// constraint (height tracks content, ~110px for logo cards).
const layoutClass =
  align === "topLeft"
    ? "items-start text-left p-8 sm:p-10"
    : "items-center justify-center text-center p-8 sm:p-12";
---

<a
  href={url}
  {...externalAttrs}
  aria-label={title}
  class="group relative block min-h-[150px] overflow-hidden rounded-2xl bg-pink-softer transition-transform hover:-translate-y-0.5"
>
  {
    bgSrc && (
      <img
        src={bgSrc}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        decoding="async"
      />
    )
  }
  {
    !bgSrc && (
      <div
        class={`relative z-[1] flex h-full flex-col gap-1 ${layoutClass} ${
          align === "center" ? "justify-center" : ""
        }`}
      >
        {thumbSrc && (
          <img
            src={thumbSrc}
            alt={title}
            class="max-h-10 sm:max-h-12 w-auto object-contain"
            loading="lazy"
          />
        )}
        {!thumbSrc && (
          <h3 class="font-display text-xl sm:text-2xl text-link-blue">
            {title}
          </h3>
        )}
        {subtitle && <p class="text-sm sm:text-base text-link-blue">{subtitle}</p>}
        {cta && <p class="text-sm text-link-blue">{cta}</p>}
      </div>
    )
  }
</a>
