---
import { asset } from "../../lib/asset";

export interface Props {
  title: string;
  subtitle?: string;
  url: string;
  thumbnail: string;
  cta: string;
  featured?: boolean;
}

const {
  title,
  subtitle,
  url,
  thumbnail,
  cta,
  featured = false,
} = Astro.props;

const thumbSrc = asset(thumbnail);

const isExternal = /^https?:/.test(url);
const externalAttrs = isExternal
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

<a
  href={url}
  {...externalAttrs}
  class={`group flex flex-col overflow-hidden rounded-3xl bg-white/70 shadow-soft ring-1 ring-ink/5 transition-all hover:-translate-y-0.5 hover:shadow-lg ${
    featured ? "sm:col-span-2" : ""
  }`}
>
  <div class="aspect-[16/9] w-full overflow-hidden bg-pink-softer">
    <img
      src={thumbSrc}
      alt=""
      loading="lazy"
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
      width="640"
      height="360"
    />
  </div>
  <div class="flex flex-1 flex-col gap-2 p-5">
    <h3 class="font-display text-xl font-semibold text-ink">{title}</h3>
    {subtitle && <p class="text-sm text-ink/70">{subtitle}</p>}
    <span
      class="mt-3 inline-flex items-center gap-1 self-start text-sm font-medium text-red-500"
    >
      {cta}
      <span aria-hidden="true">→</span>
    </span>
  </div>
</a>
