---
import { asset } from "../../lib/asset";

export interface Props {
  title: string;
  subtitle?: string;
  url: string;
  thumbnail?: string;
  bgImage?: string;
  cta?: string;
  align?: "center" | "topLeft";
}

const {
  title,
  subtitle,
  url,
  thumbnail,
  bgImage,
  cta,
  align = "center",
} = Astro.props;

const thumbSrc = thumbnail ? asset(thumbnail) : null;
const bgSrc = bgImage ? asset(bgImage) : null;

const isExternal = /^https?:|^mailto:/.test(url);
const externalAttrs = isExternal
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};

const layoutClass =
  align === "topLeft"
    ? "items-start text-left p-6 sm:p-8"
    : "items-center justify-center text-center p-6 sm:p-8";
---

<a
  href={url}
  {...externalAttrs}
  class="group relative block aspect-[5/3] overflow-hidden rounded-3xl bg-pink-soft transition-transform hover:-translate-y-0.5"
>
  {
    bgSrc && (
      <img
        src={bgSrc}
        alt=""
        class="absolute inset-0 h-full w-full object-cover"
        loading="lazy"
        decoding="async"
      />
    )
  }
  <div
    class={`relative z-[1] flex h-full flex-col gap-1 ${layoutClass} ${
      align === "center" ? "justify-center" : ""
    }`}
  >
    {
      thumbSrc && (
        <img
          src={thumbSrc}
          alt=""
          class="mb-2 h-10 w-auto sm:h-12"
          loading="lazy"
        />
      )
    }
    <h3 class="font-display text-xl sm:text-2xl text-link-blue">
      {title}
    </h3>
    {subtitle && <p class="text-sm sm:text-base text-link-blue">{subtitle}</p>}
    {cta && <p class="text-sm text-link-blue">{cta}</p>}
  </div>
</a>
