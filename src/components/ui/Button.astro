---
export interface Props {
  href?: string;
  variant?: "primary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  class?: string;
  type?: "button" | "submit";
  external?: boolean;
}

const {
  href,
  variant = "primary",
  size = "md",
  class: className = "",
  type = "button",
  external = false,
} = Astro.props;

// Source uses 1.5px outline borders and a soft cream fill (matches body).
const variants = {
  primary:
    "bg-red-500 text-white hover:bg-red-600 active:bg-red-700",
  outline:
    "bg-cream text-red-500 border-[1.5px] border-red-500 hover:bg-red-50 active:bg-red-100",
  ghost: "bg-transparent text-ink hover:text-red-500",
};

// Padding values from source: sm 12/20, md 14/22, lg 16/24.
const sizes = {
  sm: "px-5 py-3 text-sm",
  md: "px-[22px] py-3.5 text-[0.95rem]",
  lg: "px-6 py-4 text-base",
};

// Source uses 10px square-ish radius (not pill) and a heavy 700 weight.
const base =
  "inline-flex items-center justify-center gap-2 rounded-[10px] font-bold leading-none transition-all duration-150 disabled:opacity-60 disabled:pointer-events-none";

const cls = `${base} ${variants[variant]} ${sizes[size]} ${className}`;

const externalAttrs = external
  ? { target: "_blank", rel: "noopener noreferrer" }
  : {};
---

{
  href ? (
    <a href={href} class={cls} {...externalAttrs}>
      <slot />
    </a>
  ) : (
    <button type={type} class={cls}>
      <slot />
    </button>
  )
}
