---
export interface Props {
  value: string;
  label: string;
  sublabel?: string;
  accent?: "red" | "ink";
}

const { value, label, sublabel, accent = "red" } = Astro.props;
const valueClass = accent === "red" ? "text-red-500" : "text-ink";
---

<div class="flex flex-col items-center text-center sm:items-start sm:text-left">
  <span class={`font-display text-5xl sm:text-6xl font-semibold leading-none ${valueClass}`}>
    {value}
  </span>
  <span class="mt-3 font-display text-xl font-medium text-ink">{label}</span>
  {sublabel && <span class="mt-1 text-sm text-ink/65">{sublabel}</span>}
</div>
