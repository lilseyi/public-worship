---
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Container from "../ui/Container.astro";
import { asset } from "../../lib/asset";
---

<section class="relative pt-4 pb-10 sm:pt-8 sm:pb-16 overflow-hidden">
  {/* Decor objects.
   * Source positions (1280px viewport) place these near the page edges,
   * partly off-canvas, with the upper pair pulled above the eyebrow line. */}
  <img
    src={asset("/decor/flag.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: -20deg;"
    class="hidden md:block absolute left-[2%] top-[60px] h-[110px] w-auto lg:h-[120px] origin-center"
  />
  <img
    src={asset("/decor/idea.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: 30deg;"
    class="hidden md:block absolute right-[2%] top-[40px] h-[150px] w-auto lg:h-[170px] origin-center"
  />
  <img
    src={asset("/decor/heart.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: 15deg;"
    class="hidden md:block absolute -left-[60px] top-[58%] h-[170px] w-auto lg:h-[200px] origin-center"
  />
  <img
    src={asset("/decor/sunny.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: -15deg;"
    class="hidden md:block absolute -right-[60px] top-[58%] h-[170px] w-auto lg:h-[200px] origin-center"
  />

  <div class="md:hidden flex justify-center gap-3 mb-6 px-5">
    <img src={asset("/decor/flag.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
    <img src={asset("/decor/heart.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
    <img src={asset("/decor/sunny.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
  </div>

  <Container size="default" class="relative">
    <div class="flex flex-col items-center text-center gap-7" data-animate="fade-up">
      <Eyebrow>Worship with us</Eyebrow>

      {/* H1 size from source: 68px / 1.08. Corben at 700 weight is too heavy
       * because the font ships only 400 / 700; we keep font-normal here. */}
      <h1
        class="font-display font-normal text-ink leading-[1.08] text-4xl sm:text-5xl md:text-[68px] max-w-3xl"
      >
        Together, Let's Forge a Future of
        <span class="text-red-500">Bold and Radical Jesus Worship</span>
      </h1>

      {/* Source: 20px / 1.44, full ink color, max-width 480px. */}
      <p class="max-w-[480px] text-lg sm:text-xl leading-[1.44] text-ink">
        We're building a Revelations 7:9 future where every nation, tribe and
        tongue will worship God in spirit and in truth.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <Button
          href="https://givebutter.com/publicworship"
          variant="primary"
          size="lg"
          external
        >
          Make a Donation
        </Button>
        <Button href={asset("/ge")} variant="outline" size="lg">About Public Worship</Button>
      </div>
    </div>
  </Container>

  {/* Source video container is roughly 3:2 (1184x792) with 16px radius. */}
  <Container size="wide" class="mt-12 sm:mt-14">
    <div
      class="overflow-hidden rounded-2xl aspect-[3/2] bg-ink/10"
      data-animate="fade-up"
    >
      <video
        class="block h-full w-full object-cover"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        poster={asset("/images/event-1.png")}
        aria-hidden="true"
      >
        <source src={asset("/videos/hero.webm")} type="video/webm" />
        <source src={asset("/videos/hero.mp4")} type="video/mp4" />
      </video>
    </div>
  </Container>
</section>
