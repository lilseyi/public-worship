---
import Button from "../ui/Button.astro";
import Eyebrow from "../ui/Eyebrow.astro";
import Container from "../ui/Container.astro";
import { asset } from "../../lib/asset";
---

<section class="relative pt-12 pb-16 sm:pt-16 sm:pb-20 min-h-[680px] md:min-h-[760px] overflow-hidden">
  {/* Decor frames the H1+buttons in the four corners of the hero block.
   * Source places them in the gutters outside the centered content column,
   * so we use percentage insets that sit OUTSIDE the title's max-width. */}
  <img
    src={asset("/decor/flag.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: -22deg;"
    class="hidden md:block absolute left-[8%] lg:left-[14%] top-[110px] lg:top-[120px] h-[110px] w-auto lg:h-[125px] origin-center"
  />
  <img
    src={asset("/decor/idea.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: 33deg;"
    class="hidden md:block absolute right-[6%] lg:right-[10%] top-[80px] lg:top-[90px] h-[150px] w-auto lg:h-[167px] origin-center"
  />
  <img
    src={asset("/decor/heart.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: 15deg;"
    class="hidden md:block absolute left-[6%] lg:left-[10%] bottom-[80px] lg:bottom-[60px] h-[170px] w-auto lg:h-[200px] origin-center"
  />
  <img
    src={asset("/decor/sunny.svg")}
    alt=""
    aria-hidden="true"
    data-animate="hero-object"
    style="--rot: -15deg;"
    class="hidden md:block absolute right-[5%] lg:right-[9%] bottom-[60px] lg:bottom-[40px] h-[180px] w-auto lg:h-[210px] origin-center"
  />

  <div class="md:hidden flex justify-center gap-3 mb-6 px-5">
    <img src={asset("/decor/flag.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
    <img src={asset("/decor/heart.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
    <img src={asset("/decor/sunny.svg")} alt="" aria-hidden="true" class="h-12 w-12" />
  </div>

  <Container size="default" class="relative">
    <div class="flex flex-col items-center text-center gap-7" data-animate="fade-up">
      <Eyebrow>Worship with us</Eyebrow>

      {/* H1 size from source: ~88px on desktop, 1.08 line-height. Corben ships
       * only 400/700, so font-normal is correct (semibold/medium round to 700). */}
      <h1
        class="font-display font-normal text-ink leading-[1.08] text-4xl sm:text-5xl md:text-[72px] lg:text-[88px] max-w-[820px]"
      >
        Together, Let's Forge a Future of
        <span class="text-red-500">Bold and Radical Jesus Worship</span>
      </h1>

      {/* Source: 20px / 1.44, full ink color, max-width 480px. */}
      <p class="max-w-[480px] text-lg sm:text-xl leading-[1.44] text-ink">
        We're building a Revelations 7:9 future where every nation, tribe and
        tongue will worship God in spirit and in truth.
      </p>

      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <Button
          href="https://givebutter.com/publicworship"
          variant="primary"
          size="lg"
          external
        >
          Make a Donation
        </Button>
        <Button href={asset("/ge")} variant="outline" size="lg">About Public Worship</Button>
      </div>
    </div>
  </Container>
</section>
