---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";

export interface Props {
  eyebrow?: string;
  heading?: string;
  showCards?: boolean;
}

const {
  eyebrow = "Join the Movement",
  heading,
  showCards = false,
} = Astro.props;
---

<section class="py-20 sm:py-28">
  <Container size="default">
    <div class="flex flex-col items-center text-center gap-6" data-animate="fade-up">
      <SectionHeading eyebrow={eyebrow} align="center">
        {
          heading ? (
            <Fragment set:html={heading} />
          ) : (
            <Fragment>
              Be Bold,{" "}
              <span class="text-red-500">Make a Difference</span>
            </Fragment>
          )
        }
      </SectionHeading>

      <Button
        href="https://givebutter.com/publicworship"
        variant="primary"
        size="lg"
        external
        class="mt-2"
      >
        Make a Donation
      </Button>
    </div>
  </Container>
</section>
