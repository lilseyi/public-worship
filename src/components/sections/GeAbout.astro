---
import Container from "../ui/Container.astro";
import SectionHeading from "../ui/SectionHeading.astro";

const blocks = [
  {
    title: "Who We Are",
    body: "Global Echo Charitable is a 501(c)(3) nonprofit startup committed to sharing the love of Jesus and supporting initiatives that bring light into the world. We are the parent organization behind Public Worship.",
  },
  {
    title: "What We Do",
    body: "Public Worship is a movement of worship leaders, musicians, and believers lifting up the name of Jesus in public spaces — parks, plazas, subways. Global Echo provides the structure and stewardship that keeps the movement alive.",
  },
  {
    title: "Why It Matters",
    body: "Through Global Echo, we enable tax-deductible donations, apply for grants, and direct resources toward outdoor gatherings, content production, and discipleship. Every dollar moves the mission forward.",
  },
];
---

<section id="about" class="py-20 sm:py-28 scroll-mt-16">
  <Container size="default">
    <SectionHeading eyebrow="About Us" align="center">
      Funding the right <span class="text-red-500">Initiatives</span>
    </SectionHeading>

    <div class="mt-14 grid gap-10 md:grid-cols-3">
      {
        blocks.map((b) => (
          <div class="flex flex-col gap-3 text-center md:text-left">
            <h3 class="font-display text-2xl font-semibold text-ink">
              {b.title}
            </h3>
            <p class="text-ink/75 leading-relaxed">{b.body}</p>
          </div>
        ))
      }
    </div>
  </Container>
</section>
