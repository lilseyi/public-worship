---
const currentNeeds = ["Video Editors", "Color Graders"];

const futureNeeds = [
  "Live Sound Engineers",
  "Graphic Designers",
  "Event Planners",
  "Project Managers",
  "Songwriters",
  "Cinematographers",
  "Greeters",
];
---

<div class="grid gap-10 sm:grid-cols-2 max-w-3xl">
  <div>
    <h3 class="font-display text-xl font-normal text-ink mb-3">
      Current Needs (As of Sept 2025)
    </h3>
    <ul class="flex flex-col gap-1 text-ink/80">
      {currentNeeds.map((n) => <li>– {n}</li>)}
    </ul>
  </div>

  <div>
    <h3 class="font-display text-xl font-normal text-ink mb-3">
      Anticipated Needs for 2026
    </h3>
    <ul class="flex flex-col gap-1 text-ink/80">
      {futureNeeds.map((n) => <li>– {n}</li>)}
    </ul>
  </div>
</div>
